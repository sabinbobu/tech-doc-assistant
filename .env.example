# ── API Keys ──
# Get your OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key-here"

# Get your Anthropic key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# ── LLM Settings ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── Chunking ──
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ──
RETRIEVAL_TOP_K=5
